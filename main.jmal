%define.table my_table
    rule1: [register, string]
    rule2: [register, address]
%undef

%type my_type: string | number | register

%define my_string "This is my string!"

%use my_table
%macro.strict mov 2
    %arg %1 : my_type
    %arg %2 : string

    ; Note: do the actuall process here
%endmacro

%use my_table
%macro.strict sub 2
    %arg %1 : register
    %arg %2 : register

    ; Note: do the actuall process here
%endmacro

%macro push_macro 1-3
    %arg %1 : my_type
    %arg %2 : string | number | register
    %arg %3 : my_type

    %rep %0
        push %1
        %rotate 1
    %endrep
%endmacro
