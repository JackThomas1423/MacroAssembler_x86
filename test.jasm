[BITS 64]

section .text

global _start

_start:
    push back "Function test works!", 10 as BYTE
    call test_function
    print 21
    exit 0

@test_function: [ buffer: resb 12, other: resb 12 ]
    push back "Hello world!", 10 as BYTE
    push buffer as PTR
    pop rbx as PTR
    mov BYTE [rbx], 'a'
    mov BYTE [rbx+1], 'b'

    mov rax, 1
    mov rdi, 1
    mov rsi, rbx
    mov rdx, 3
    syscall

    leave